# Required
MONGO_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/admin?retryWrites=true&w=majority&tls=true
SPACE_NAME=your-space-name
SPACE_ENDPOINT=https://fra1.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=your_spaces_key
AWS_SECRET_ACCESS_KEY=your_spaces_secret
BACKUP_PASSPHRASE=replace_with_strong_random_secret
CRON_SCHEDULE="15 3 * * 0"

# Optional
TZ=Etc/UTC
RETENTION=6
EXTRA_MONGODUMP_ARGS=
AWS_S3_FORCE_PATH_STYLE=false
MONGO_TLS_CA_FILE=
BACKUP_PASSPHRASE_FILE=
RUN_ON_START=false

# Restore-only
S3_OBJECT_KEY=
RESTORE_VERIFY_CHECKSUM=true
EXTRA_MONGORESTORE_ARGS=
